{
  "cSpell.ignoreWords": [
    "",
    "abcdefghijklmnopqrstuvwxwz",
    "arraybuffer",
    "bodyparser",
    "chunkhash",
    "colsum",
    "csrf",
    "dijsktra",
    "f",
    "fres",
    "heapify",
    "inorder",
    "leetcode",
    "microtask",
    "middlewares",
    "numberic",
    "nums",
    "postorder",
    "preorder",
    "ref",
    "referer",
    "rowsum",
    "ttfb",
    "unhandledrejection",
    "unsubcribe",
    "xsrf"
  ],
  "cSpell.words": [
    "deepagents",
    "numberic",
    "tapable",
    "typeof"
],
  "files.exclude": {
    "desktop.ini": true
  },
  "compile-hero.disable-compile-files-on-did-save-code": false,
  "trae.tab.enableRename": false,
  "trae.tab.enableAutoImport": false,
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.detectIndentation": false,
  "[python]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": true
},
"python-envs.defaultEnvManager": "ms-python.python:conda",
"python-envs.defaultPackageManager": "ms-python.python:conda"
}